{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "ignoreCommand": "exit 1",
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "functions": {
    "api/mbti/question.js": {
      "maxDuration": 10
    },
    "api/mbti/submit.js": {
      "maxDuration": 10
    }
  }
}
